  "keyFeatures": [
    "Interactive educational content authoring",
    "Real-time collaborative editing with Yjs",
    "Multi-format export (HTML5, SCORM 1.2/2004, EPUB3, IMS CP)",
    "Browser-first architecture with offline support",
    "Extensive iDevice library for interactive elements",
    "Multi-database support (SQLite, PostgreSQL, MySQL)",
    "Desktop applications for Windows, macOS, and Linux",
    "RESTful API for external integrations",
    "Embeddable in LMS platforms",
    "Custom theme support",
    "Multilingual interface"
  ],
  "publicApiSurface": [
    "POST /api/v1/auth/login - Authenticate user",
    "POST /api/v1/projects - Create project",
    "GET /api/v1/projects/:uuid - Get project",
    "PUT /api/v1/projects/:uuid - Update project",
    "POST /api/v1/projects/:uuid/pages - Create page",
    "POST /api/v1/projects/:uuid/export - Export project",
    "GET /api/v1/assets/:id - Get asset",
    "WebSocket /yjs/project-{uuid} - Real-time collaboration",
    "CLI: exelearning elp:convert - Convert ELP files",
    "CLI: exelearning elp:export - Export projects",
    "CLI: exelearning migrate - Run database migrations",
    "CLI: exelearning create-user - Create user account"
  ]
